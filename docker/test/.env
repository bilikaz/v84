# Test stack — fully isolated from dev.
# These values are safe to commit — they're throwaway test credentials.

# Unlocks the TestModule in the API (exposes POST /api/v1/test/reset so e2e
# tests can re-seed between runs). AppModule conditionally imports it only
# when NODE_ENV === 'test'.
NODE_ENV=test

DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_NAME=test
DATABASE_USER=test
DATABASE_PASSWORD=test
DATABASE_ROOT_PASSWORD=test

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=test-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_PASSWORD_RESET_TTL=3600
JWT_PASSWORD_RESET_PREFIX=reset:
JWT_EMAIL_VERIFICATION_TTL=86400
JWT_EMAIL_VERIFICATION_PREFIX=verify:

# Auth rate limit — effectively disabled for the test stack so e2e can hammer
# /auth/login and /auth/refresh freely. Prod/dev use the defaults (10/60s).
AUTH_THROTTLE_TTL=60000
AUTH_THROTTLE_LIMIT=100000

MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_HTTP_PORT=8025
MAIL_FROM=test@test.local
MAIL_FROM_NAME=V84 Test

API_NAME=V84 API
API_DESCRIPTION=V84 API
API_PREFIX=api/v1
API_PORT=3001
API_REGISTRATION_ENABLED=1
WEB_URL=http://web:3000

API_URL=http://api:3001/api/v1
SESSION_COOKIE=session

GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
