# [v84-1-2][ops:infra]
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (config/database.config.ts)
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_NAME=local
DATABASE_USER=local
DATABASE_PASSWORD=local
DATABASE_ROOT_PASSWORD=local

# Redis (config/redis.config.ts)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (config/jwt.config.ts) — [v84-2-1-1][ops:infra]
JWT_SECRET=dev-secret-change-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_PASSWORD_RESET_TTL=3600
JWT_PASSWORD_RESET_PREFIX=reset:
JWT_EMAIL_VERIFICATION_TTL=86400
JWT_EMAIL_VERIFICATION_PREFIX=verify:

# Mail (config/mail.config.ts) — MailPit catches everything in dev
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=V84

# API (config/app.config.ts)
API_NAME=V84 API
API_DESCRIPTION=V84 API
API_PREFIX=api/v1
API_PORT=3001
WEB_PORT=3000
STORYBOOK_PORT=6006
API_REGISTRATION_ENABLED=1
WEB_URL=http://web.localhost
# CORS is disabled by default — browser talks to BFF, BFF talks to api server-side.
CORS_ORIGINS=

# BFF (apps/web/src/config/server-env.ts) — [v84-2-1-1][ops:infra]
API_URL=http://api:3001/api/v1
SESSION_COOKIE=session
# SESSION_COOKIE_MAX_AGE=2592000
# SESSION_REFRESH_THRESHOLD=15

# Google OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
